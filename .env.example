# ─── API Keys ───────────────────────────────────────────────
# At least one of these is required for AI features.
GEMINI_API_KEY=
OPENAI_API_KEY=

# ElevenLabs API key for realistic text-to-speech (optional, falls back to browser TTS).
ELEVENLABS_API_KEY=

# ─── Database ───────────────────────────────────────────────
DATABASE_PATH=./data/interview-loop.sqlite

# ─── TTS Provider ──────────────────────────────────────────
# "elevenlabs" = high quality AI voices (costs credits)
# "browser"    = free browser Web Speech API (no credits needed)
TTS_PROVIDER=elevenlabs

# ─── AI Provider ───────────────────────────────────────────
# Global default: "gemini" or "openai"
AI_PROVIDER=gemini

# Per-task overrides (optional — leave blank to use AI_PROVIDER).
# Uncomment and set to "gemini" or "openai" to override individually.
# AI_PROVIDER_RESUME=          # Resume parsing
# AI_PROVIDER_JOB=             # Job description analysis
# AI_PROVIDER_VALIDATE=        # CV validation
# AI_PROVIDER_COMPANY=         # Company name resolution
# AI_PROVIDER_RESEARCH=        # Deep company research
# AI_PROVIDER_PANEL=           # Interviewer persona generation
# AI_PROVIDER_PLAN=            # Interview plan building
# AI_PROVIDER_INTERVIEW=       # Live interview turns
# AI_PROVIDER_EVALUATE=        # Session evaluation & scoring
# AI_PROVIDER_COACH=           # Coaching & answer rewrites

# ─── Model Selection ──────────────────────────────────────
# Gemini models (used when provider = gemini)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LITE_MODEL=gemini-2.5-flash-lite

# OpenAI models (used when provider = openai)
OPENAI_MODEL=gpt-4o-mini
OPENAI_SMART_MODEL=gpt-4o

# ─── Feature Flags ─────────────────────────────────────────
ENABLE_VOICE=true
ENABLE_SEARCH_PAGE=false
ENABLE_DEMO_MODE=true
